# Get a Gemini API key from https://aistudio.google.com/api-keys and set it here.
# Note that the free tier may not be sufficient for running a single full pipeline, due to token and rate limits.
# The code is hard-coded to use gemini-2.5-flash, which may be sunset in the future. If that happens, you need to switch to a different model and may need to update the realiser prompts accordingly.
GEMINI_API_KEY=your_gemini_api_key_here

# Set to "true" to run the pipeline without calling the Gemini API.
# Realisers will write their LLM request JSON instead of generating text.
DISABLE_LLM=true
