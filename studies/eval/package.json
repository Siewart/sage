{
  "name": "@1001tales/eval-study",
  "private": true,
  "packageManager": "yarn@4.9.3",
  "scripts": {
    "lint": "Rscript -e \"lintr::lint_dir('analysis')\"",
    "format": "Rscript -e \"styler::style_dir('analysis')\"",
    "dev": "Rscript analysis/run_all.R",
    "dev:power": "Rscript analysis/run_all.R --with-power",
    "docker:build": "docker build -t eval-analysis .",
    "docker:run": "docker run --rm -v \"$(pwd)\":/work eval-analysis",
    "docker:power": "docker run --rm -v \"$(pwd)\":/work eval-analysis --with-power"
  }
}
