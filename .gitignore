# Thesis LaTeX build artifacts
# Ignore the directory's contents but keep the final PDF (see negation below)
/thesis/latex/.build/*
!/thesis/latex/.build/main.pdf
/thesis/latex/*.aux
/thesis/latex/*.log
/thesis/latex/*.toc
/thesis/latex/*.out
/thesis/latex/*.lof
/thesis/latex/*.lot
/thesis/latex/*.fls
/thesis/latex/*.fdb_latexmk
/thesis/latex/*.synctex.gz

